# SigTekX - StreamingExecutor Pipeline Sequence
# Layout: elk - complex sequence diagram with multiple actors and parallel flows
# Render: See docs/diagrams/README.md for rendering instructions
#
# This diagram shows the complete execution flow for StreamingExecutor (low-latency streaming mode).
# The sequence illustrates ring buffer accumulation, zero-copy peek_frame DMA, and 3-stream asynchronous execution.

# Import shared styles
...@common/styles

direction: down

# ==============================================================================
# Streaming Executor Pipeline (Continuous Streaming Mode)
# ==============================================================================
streaming_mode: Streaming Executor Pipeline {
  class: streaming-green

  description: |md
    **Streaming Mode: Ring Buffer Accumulation + Frame Extraction**
    - Supports arbitrary input chunk sizes
    - Per-channel independent processing
    - Ring buffer capacity: 3× NFFT per channel
    - Mean latency: 122.25 µs (+40% vs batch)
    - Ideal for real-time continuous streaming
  |

  # Actor definitions
  Client: {shape: rectangle}
  StreamingExecutor: {shape: rectangle}
  Impl: {
    shape: rectangle
    label: "StreamingExecutor::Impl"
  }
  RingBuffer: {
    shape: rectangle
    label: "RingBuffer[ch]\n(pinned)"
  }
  Stream0: {
    shape: rectangle
    label: "Stream[0]\nH2D"
  }
  Stream1: {
    shape: rectangle
    label: "Stream[1]\nCompute"
  }
  Stream2: {
    shape: rectangle
    label: "Stream[2]\nD2H"
  }
  WindowStage: {shape: rectangle}
  FFTStage: {shape: rectangle}
  MagnitudeStage: {shape: rectangle}

  # Sequence flow
  Client -> StreamingExecutor: "1: submit(input, output, num_samples)"
  StreamingExecutor -> Impl: "2: submit_impl(input, output, num_samples)"

  # Ring Buffer Accumulation
  Impl -> RingBuffer: "3: for each channel:\npush(input_chunk[ch], num_samples)"
  RingBuffer -> RingBuffer: "4: Lock-free push\nAtomic write_pos update"
  RingBuffer -> Impl: "5: push complete"

  # Frame Extraction Loop (while can_extract_frame(nfft))
  Impl -> RingBuffer: "6: peek_frame(nfft)\n(Zero-copy: returns FrameView spans)"
  RingBuffer -> RingBuffer: "7: Returns FrameView{first, second}\n(ptrs into pinned ring buf memory)"

  # Host to Device Transfer (direct DMA from pinned ring buffer — no staging copy)
  RingBuffer -> Stream0: "8: cudaMemcpyAsync(d_input, view.first)\n(Direct DMA from pinned memory)"
  Stream0 -> Stream0: "9: [if wraparound] cudaMemcpyAsync(view.second)\nthen record event_h2d_done"

  # Compute Pipeline
  Stream1 -> Stream0: "10: wait(event_h2d_done)"
  Stream1 -> WindowStage: "11: process(d_input, d_input)"
  WindowStage -> WindowStage: "12: apply_window_kernel<<<>>>\n(Shape: [channels, nfft])"

  Stream1 -> FFTStage: "13: process(d_input, d_intermediate)"
  FFTStage -> FFTStage: "14: cufftExecR2C()\n(Output: [channels, nfft/2+1])"

  Stream1 -> MagnitudeStage: "15: process(d_intermediate, d_output)"
  MagnitudeStage -> MagnitudeStage: "16: magnitude_kernel<<<>>>\n(Shape: [channels, bins])"

  Stream1 -> Stream1: "17: record event_compute_done"

  # Device to Host Transfer
  Stream2 -> Stream1: "18: wait(event_compute_done)"
  Stream2 -> Stream2: "19: copy_to_host(output_frame)\n(Transfer one frame result)"

  Impl -> Impl: "20: frames_processed++"

  # End Frame Extraction Loop - Synchronization then advance
  Impl -> Stream2: "21: synchronize()\n(Wait for D2H — keeps peek ptrs valid)"
  Stream2 -> Impl: "22: D2H complete"

  # Advance AFTER sync so peek pointers remain valid during DMA
  Impl -> RingBuffer: "23: advance(hop_size)\n(Move read pointer — safe after sync)"

  Impl -> Impl: "24: update_stats(event_start, event_end)\n(Update latency, throughput, frames_processed)"

  Impl -> StreamingExecutor: "25: submit complete"
  StreamingExecutor -> Client: "26: return (last frame in output)"

  performance_stream_note: {
    class: note-gold
    label: |md
      **Performance**: Mean latency ~122 µs (+40% vs batch, pre-Phase 1.1 baseline)
      **Zero-copy DMA**: peek_frame() eliminates staging buffer memcpy
      **Ring buffer overhead**: push memcpy + per-channel loop (~20 µs)

      Tradeoff: Flexibility for arbitrary chunk sizes
      Ideal for real-time continuous streaming
    |
  }
}

# ==============================================================================
# Comparison Note
# ==============================================================================
comparison: |md
  # Batch vs Streaming Mode Comparison

  ## Batch Executor (High-Throughput - see 06_cpp_seq_batch.d2)
  - **Direct pipeline**: H2D → Compute → D2H
  - **Fixed input size**: Must provide complete frames
  - **Lower latency**: 86.79 µs
  - **Lower memory**: 164 KB
  - **Use case**: Offline batch processing, file analysis

  ## Streaming Executor (Low-Latency Real-Time - THIS DIAGRAM)
  - **Ring buffer accumulation**: Flexible chunk sizes
  - **Zero-copy H2D**: peek_frame() DMA directly from pinned ring buffer (Phase 1.1)
  - **Higher latency**: ~122 µs (+40%)
  - **Higher memory**: ~262 KB (+60%)
  - **Use case**: Real-time streaming, continuous monitoring

  Both modes use the same 3-stream asynchronous pipeline for parallel H2D/Compute/D2H.
|

comparison.class: core-blue
