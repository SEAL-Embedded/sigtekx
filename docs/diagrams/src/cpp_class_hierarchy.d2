# Ionosense HPC Library - C++ Architecture (v0.9.4+ Executor-Based)
# D2 Diagram - © 2025 | Updated: 2025-01-19

direction: right
layout-engine: elk

# ==============================================================================
# Executor API Layer
# ==============================================================================
executor_layer: Executor API Layer {
  style: {
    fill: "#E6F3FF"
    stroke: "#4169E1"
  }

  IPipelineExecutor: {
    shape: class
    label: "«interface»\nIPipelineExecutor"

    # Abstract methods
    "+initialize(config: ExecutorConfig, stages: vector<IProcessingStage>): void": ""
    "+submit(input: float*, output: float*, num_samples: size_t): void": ""
    "+submit_async(input: float*, num_samples: size_t, callback: ResultCallback): void": ""
    "+synchronize(): void": ""
    "+get_stats(): ProcessingStats": ""
    "+get_runtime_info(): RuntimeInfo": ""
    "+supports_streaming(): bool": ""
  }

  BatchExecutor: {
    shape: class

    "-pImpl: unique_ptr<Impl>": ""
    "": ""
    "+BatchExecutor()": ""
    "+~BatchExecutor()": ""
    "+initialize(config: ExecutorConfig, stages: vector<IProcessingStage>): void": ""
    "+submit(input: float*, output: float*, num_samples: size_t): void": ""
    "+submit_async(input: float*, num_samples: size_t, callback: ResultCallback): void": ""
    "+synchronize(): void": ""
    "+get_stats(): ProcessingStats": ""
    "+supports_streaming(): bool // returns false": ""
  }

  BatchExecutor_Impl: {
    shape: class
    label: "«Pimpl»\nBatchExecutor::Impl"

    "-config_: ExecutorConfig": ""
    "-device_id_: int": ""
    "-stages_: vector<unique_ptr<IProcessingStage>>": ""
    "-streams_: vector<CudaStream>": ""
    "-events_: vector<CudaEvent>": ""
    "-d_input_buffers_: vector<DeviceBuffer<float>>": ""
    "-h_input_staging_: PinnedHostBuffer<float>": ""
    "-stats_: ProcessingStats": ""
    "": ""
    "+submit_impl(input: float*, output: float*, num_samples: size_t): void": ""
    "+run_warmup(): void": ""
    "+update_stats(start_event: CudaEvent&, end_event: CudaEvent&): void": ""
  }

  StreamingExecutor: {
    shape: class

    "-pImpl: unique_ptr<Impl>": ""
    "": ""
    "+StreamingExecutor()": ""
    "+~StreamingExecutor()": ""
    "+initialize(config: ExecutorConfig, stages: vector<IProcessingStage>): void": ""
    "+submit(input: float*, output: float*, num_samples: size_t): void": ""
    "+synchronize(): void": ""
    "+supports_streaming(): bool // returns true": ""
  }

  StreamingExecutor_Impl: {
    shape: class
    label: "«Pimpl»\nStreamingExecutor::Impl"

    "-config_: ExecutorConfig": ""
    "-input_ring_buffers_: vector<RingBuffer<float>>": ""
    "-streams_: vector<CudaStream>": ""
    "-h_batch_staging_: PinnedHostBuffer<float>": ""
    "-stats_: ProcessingStats": ""
    "": ""
    "+submit_impl(input: float*, output: float*, num_samples: size_t): void": ""
    "+process_accumulated_frames(): void": ""
  }

  # Executor relationships
  BatchExecutor -> IPipelineExecutor: implements {
    style.stroke-dash: 3
    target-arrowhead.shape: triangle
  }

  StreamingExecutor -> IPipelineExecutor: implements {
    style.stroke-dash: 3
    target-arrowhead.shape: triangle
  }

  BatchExecutor -> BatchExecutor_Impl: owns (Pimpl) {
    style.stroke: "#4169E1"
    target-arrowhead.shape: diamond
  }

  StreamingExecutor -> StreamingExecutor_Impl: owns (Pimpl) {
    style.stroke: "#4169E1"
    target-arrowhead.shape: diamond
  }
}

# ==============================================================================
# Ring Buffer for Streaming
# ==============================================================================
ring_buffer_layer: Ring Buffer for Streaming {
  style: {
    fill: "#E6FFE6"
    stroke: "#228B22"
  }

  RingBuffer: {
    shape: class
    label: "«template»\nRingBuffer<T>"

    "-buffer_: PinnedHostBuffer<T>": ""
    "-capacity_: size_t": ""
    "-write_pos_: atomic<size_t>": ""
    "-read_pos_: atomic<size_t>": ""
    "-available_: atomic<size_t>": ""
    "": ""
    "+RingBuffer(capacity: size_t)": ""
    "+push(data: T*, count: size_t): void": ""
    "+extract_frame(output: T*, frame_size: size_t): void": ""
    "+extract_batch(output: T*, nfft: size_t, num_frames: size_t, hop_size: size_t): void": ""
    "+advance(samples: size_t): void": ""
    "+can_extract(frame_size: size_t): bool": ""
  }
}

# ==============================================================================
# Processing Stage Layer
# ==============================================================================
stage_layer: Processing Stage Layer {
  style: {
    fill: "#E6F3FF"
    stroke: "#4169E1"
  }

  IProcessingStage: {
    shape: class
    label: "«interface»\nIProcessingStage"

    "+initialize(config: StageConfig, stream: cudaStream_t): void": ""
    "+process(input: void*, output: void*, num_elements: size_t, stream: cudaStream_t): void": ""
    "+name(): string": ""
    "+supports_inplace(): bool": ""
    "+get_workspace_size(): size_t": ""
  }

  WindowStage: {
    shape: class
    "-pImpl: unique_ptr<Impl>": ""
    "": ""
    "+initialize(config: StageConfig, stream: cudaStream_t): void": ""
    "+process(input: void*, output: void*, num_samples: size_t, stream: cudaStream_t): void": ""
    "+name(): string": ""
  }

  FFTStage: {
    shape: class
    "-pImpl: unique_ptr<Impl>": ""
    "": ""
    "+initialize(config: StageConfig, stream: cudaStream_t): void": ""
    "+process(input: void*, output: void*, num_samples: size_t, stream: cudaStream_t): void": ""
  }

  MagnitudeStage: {
    shape: class
    "-pImpl: unique_ptr<Impl>": ""
    "": ""
    "+initialize(config: StageConfig, stream: cudaStream_t): void": ""
    "+process(input: void*, output: void*, num_samples: size_t, stream: cudaStream_t): void": ""
  }

  StageFactory: {
    shape: class
    label: "«Singleton»\nStageFactory"
    "+create(type: StageType): unique_ptr<IProcessingStage> «static»": ""
    "+create_default_pipeline(): vector<unique_ptr<IProcessingStage>> «static»": ""
  }

  StageType: {
    shape: class
    label: "«enum»\nStageType"
    "WINDOW": ""
    "FFT": ""
    "MAGNITUDE": ""
  }

  # Stage relationships
  WindowStage -> IProcessingStage: implements {
    style.stroke-dash: 3
    target-arrowhead.shape: triangle
  }

  FFTStage -> IProcessingStage: implements {
    style.stroke-dash: 3
    target-arrowhead.shape: triangle
  }

  MagnitudeStage -> IProcessingStage: implements {
    style.stroke-dash: 3
    target-arrowhead.shape: triangle
  }

  StageFactory -> WindowStage: creates {
    style.stroke-dash: 3
  }

  StageFactory -> FFTStage: creates {
    style.stroke-dash: 3
  }

  StageFactory -> MagnitudeStage: creates {
    style.stroke-dash: 3
  }
}

# ==============================================================================
# CUDA Resource Management
# ==============================================================================
cuda_layer: CUDA Resource Management {
  style: {
    fill: "#D4E6FF"
    stroke: "#4169E1"
  }

  CudaStream: {
    shape: class
    label: "«RAII»\nCudaStream"

    "-stream_: cudaStream_t": ""
    "-owned_: bool": ""
    "": ""
    "+CudaStream()": ""
    "+get(): cudaStream_t": ""
    "+synchronize(): void": ""
    "+query(): bool": ""
    "...Move-only semantics...": ""
  }

  CudaEvent: {
    shape: class
    label: "«RAII»\nCudaEvent"

    "-event_: cudaEvent_t": ""
    "": ""
    "+record(stream: cudaStream_t): void": ""
    "+synchronize(): void": ""
    "+elapsed_ms(start: CudaEvent&): float": ""
  }

  DeviceBuffer: {
    shape: class
    label: "«RAII»\nDeviceBuffer<T>"

    "-ptr_: T*": ""
    "-size_: size_t": ""
    "": ""
    "+get(): T*": ""
    "+size(): size_t": ""
    "+copy_from_host(host_ptr: T*, count: size_t, stream: cudaStream_t): void": ""
    "+copy_to_host(host_ptr: T*, count: size_t, stream: cudaStream_t): void": ""
  }

  PinnedHostBuffer: {
    shape: class
    label: "«RAII»\nPinnedHostBuffer<T>"

    "-ptr_: T*": ""
    "-size_: size_t": ""
    "": ""
    "+get(): T*": ""
    "+size(): size_t": ""
    "+operator[](idx: size_t): T&": ""
  }

  CufftPlan: {
    shape: class
    label: "«RAII»\nCufftPlan"

    "-plan_: cufftHandle": ""
    "-work_area_: DeviceBuffer<char>": ""
    "": ""
    "+create_plan_many(...): void": ""
    "+exec_r2c(input: cufftReal*, output: cufftComplex*): void": ""
  }

  CufftPlan -> DeviceBuffer: owns work_area {
    target-arrowhead.shape: diamond
  }
}

# ==============================================================================
# Configuration & Statistics
# ==============================================================================
config_layer: Configuration & Statistics {
  style: {
    fill: "#E6F3FF"
    stroke: "#4169E1"
  }

  SignalConfig: {
    shape: class
    label: "«Data»\nSignalConfig"

    "+nfft: int = 1024": ""
    "+channels: int = 2 // Renamed from 'batch' in v0.9.4": ""
    "+overlap: float = 0.5f": ""
    "+sample_rate_hz: int = 48000": ""
    "+stream_count: int = 3": ""
    "+warmup_iters: int = 1": ""
    "": ""
    "+hop_size(): int": ""
    "+num_output_bins(): int": ""
  }

  ExecutorConfig: {
    shape: class
    label: "«Data»\nExecutorConfig"

    "+mode: ExecutionMode = BATCH": ""
    "+max_inflight_batches: int = 2": ""
    "+enable_background_thread: bool = false": ""
    "+timeout_ms: int = 1000": ""
    "+use_cuda_graphs: bool = false": ""
  }

  ExecutionMode: {
    shape: class
    label: "«enum»\nExecutionMode"
    "BATCH": ""
    "STREAMING": ""
  }

  StageConfig: {
    shape: class
    label: "«Data»\nStageConfig"

    "+nfft: int = 1024": ""
    "+channels: int = 2 // Renamed from 'batch' in v0.9.4": ""
    "+overlap: float = 0.5f": ""
    "+window_type: WindowType = HANN": ""
    "+window_symmetry: WindowSymmetry = PERIODIC": ""
    "+inplace: bool = true": ""
  }

  ProcessingStats: {
    shape: class
    label: "«Data»\nProcessingStats"

    "+latency_us: float = 0.0f": ""
    "+throughput_gbps: float = 0.0f": ""
    "+frames_processed: size_t = 0 // Temporal FFT windows": ""
    "+is_warmup: bool = true": ""
  }

  RuntimeInfo: {
    shape: class
    label: "«Data»\nRuntimeInfo"

    "+cuda_version: string": ""
    "+device_name: string": ""
    "+device_compute_capability_major: int": ""
    "+device_memory_total_mb: size_t": ""
  }

  # Config hierarchy
  ExecutorConfig -> SignalConfig: extends {
    style.stroke: "#4169E1"
    target-arrowhead.shape: triangle
  }
}

