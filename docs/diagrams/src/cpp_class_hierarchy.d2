  OpsFft: {
    shape: class
    label: "ops_fft.cu"

    "+apply_window_kernel(): __global__ void «static»": ""
    "+magnitude_kernel(): __global__ void «static»": ""
    "+scale_fft_output_kernel(): __global__ void «static»": ""
    "": ""
    "+launch_apply_window(): void «static»": ""
    "+launch_magnitude(): void «static»": ""
  }
}

# ==============================================================================
# Exception Handling
# ==============================================================================
exception_layer: Exception Handling {
  style: {
    fill: "#FFE6E6"
    stroke: "#FF6B6B"
  }

  CudaException: {
    shape: class
    "-error_: cudaError_t": ""
    "": ""
    "+CudaException(error: cudaError_t, call: char*, file: char*, line: int)": ""
    "+error(): cudaError_t": ""
  }

  CufftException: {
    shape: class
    "-result_: cufftResult": ""
    "": ""
    "+CufftException(result: cufftResult, call: char*, file: char*, line: int)": ""
    "+result(): cufftResult": ""
  }
}

# ==============================================================================
# Cross-layer Relationships
# ==============================================================================

# Executor -> Stage relationships
executor_layer.BatchExecutor_Impl -> stage_layer.IProcessingStage: manages {
  style.stroke-dash: 3
}

executor_layer.StreamingExecutor_Impl -> stage_layer.IProcessingStage: manages {
  style.stroke-dash: 3
}

executor_layer.StreamingExecutor_Impl -> ring_buffer_layer.RingBuffer: owns (per-channel) {
  target-arrowhead.shape: diamond
}

# Executor -> CUDA resources
executor_layer.BatchExecutor_Impl -> cuda_layer.CudaStream: owns {
  target-arrowhead.shape: diamond
}

executor_layer.BatchExecutor_Impl -> cuda_layer.DeviceBuffer: owns {
  target-arrowhead.shape: diamond
}

executor_layer.StreamingExecutor_Impl -> cuda_layer.PinnedHostBuffer: owns {
  target-arrowhead.shape: diamond
}

# Executor -> Config
executor_layer.BatchExecutor_Impl -> config_layer.ExecutorConfig: uses {
  style.stroke-dash: 3
}

executor_layer.BatchExecutor_Impl -> config_layer.ProcessingStats: generates {
  style.stroke-dash: 3
}

# Ring Buffer -> CUDA
ring_buffer_layer.RingBuffer -> cuda_layer.PinnedHostBuffer: owns buffer {
  target-arrowhead.shape: diamond
}

# Stages -> CUDA
stage_layer.WindowStage -> cuda_layer.DeviceBuffer: uses {
  style.stroke-dash: 3
}

stage_layer.FFTStage -> cuda_layer.CufftPlan: uses {
  style.stroke-dash: 3
}

stage_layer.MagnitudeStage -> kernel_layer.OpsFft: calls {
  style.stroke-dash: 3
}

# Stages -> Config
stage_layer.WindowStage -> config_layer.StageConfig: uses {
  style.stroke-dash: 3
}

# ==============================================================================
# Notes and Documentation
# ==============================================================================

executor_note: |md
  **v0.9.3+ Executor Pattern**

  Replaces old ResearchEngine.
  Two implementations:
  - BatchExecutor (high-throughput, 86.79 µs)
  - StreamingExecutor (low-latency, 122.25 µs)
| {
  style: {
    fill: "#FFFACD"
    stroke: "#FFD700"
  }
}

ring_buffer_note: |md
  **Ring Buffer Architecture**

  Per-channel ring buffers enable:
  - Arbitrary input chunk sizes
  - Continuous streaming
  - Independent channel processing
  - 3× NFFT capacity prevents overflow

  **Lock-Free Thread-Safe**
  Single-producer/single-consumer
  Uses atomic operations
| {
  style: {
    fill: "#FFFACD"
    stroke: "#FFD700"
  }
}

terminology_note: |md
  **Terminology (v0.9.4)**

  - channels = spatial dimension (signal sources)
  - frames = temporal dimension (FFT windows)
  - bins = spectral dimension (frequencies)
| {
  style: {
    fill: "#FFFACD"
    stroke: "#FFD700"
  }
}

raii_note: |md
  **Design Pattern: RAII**

  Automatic resource management
  Move-only semantics
  Exception-safe cleanup
| {
  style: {
    fill: "#FFFACD"
    stroke: "#FFD700"
  }
}
