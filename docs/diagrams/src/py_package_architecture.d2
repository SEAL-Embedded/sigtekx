# Future Stages Package - ionosense_hpc.stages (v2.0)
# ==============================================================================
stages_package: ionosense_hpc.stages «Future» {
  style: {
    fill: "#FFFFCC"
    stroke: "#DAA520"
    stroke-dash: 3
  }

  StageType: |md
    **StageType**
    «Enum»

    WINDOW
    FFT
    MAGNITUDE
    PHASE
    FILTER
    RESAMPLE
  |
  StageType.shape: class

  StageRegistry: |md
    **StageRegistry**

    - _stages: dict
    - _metadata: dict

    + register(name, fn, metadata): void
    + get(name): Callable
    + list_stages(): list
  |
  StageRegistry.shape: class

  StageRegistry -> StageType: manages {
    style.stroke-dash: 3
  }

  note: |md
    **v2.0 Extensibility**
    Prepared for pluggable
    processing stages in
    future releases
  |
}

