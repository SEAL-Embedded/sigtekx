# Ionosense HPC - Executor Pipeline Sequences
# Layout: elk - complex sequence diagrams with multiple actors and parallel flows
# Render: See docs/diagrams/README.md for rendering instructions
#
# This diagram shows the complete execution flow for both BatchExecutor (high-throughput)
# and StreamingExecutor (low-latency streaming) modes. The two sequences are presented
# side-by-side for comparison.

direction: down

# ==============================================================================
# Batch Executor Pipeline (High-Throughput Mode)
# ==============================================================================
batch_mode: Batch Executor Pipeline {
  style: {
    fill: "#F0F8FF"
    stroke: "#4169E1"
    stroke-width: 2
  }

  description: |md
    **Batch Mode: Direct Pipeline Processing**
    - Input shape: [channels, num_samples]
    - Output shape: [channels, num_frames, num_bins]
    - Mean latency: 86.79 µs
    - Ideal for high-throughput batch processing
  |

  # Actor definitions
  Client: {shape: rectangle}
  BatchExecutor: {shape: rectangle}
  Impl: {
    shape: rectangle
    label: "BatchExecutor::Impl"
  }
  Stream0: {
    shape: rectangle
    label: "Stream[0]\nH2D"
  }
  Stream1: {
    shape: rectangle
    label: "Stream[1]\nCompute"
  }
  Stream2: {
    shape: rectangle
    label: "Stream[2]\nD2H"
  }
  WindowStage: {shape: rectangle}
  FFTStage: {shape: rectangle}
  MagnitudeStage: {shape: rectangle}

  # Sequence flow
  Client -> BatchExecutor: "1: submit(input, output, num_samples)"
  BatchExecutor -> Impl: "2: submit_impl(input, output, num_samples)"

  process_note: {
    shape: text
    label: |md
      Process input for all channels
      Extract overlapping frames
    |
    style.stroke-width: 0
  }

  # Host to Device Transfer
  h2d_header: {
    shape: text
    label: "PPP Host to Device Transfer PPP"
    style: {
      stroke-width: 0
      font-size: 14
      bold: true
    }
  }

  Impl -> Stream0: "3: copy_from_host(input)"
  Stream0 -> Stream0: "4: record event_h2d_done\n(Async H2D on Stream 0)"

  # Compute Pipeline
  compute_header: {
    shape: text
    label: "PPP Compute Pipeline PPP"
    style: {
      stroke-width: 0
      font-size: 14
      bold: true
    }
  }

  Stream1 -> Stream0: "5: wait(event_h2d_done)\n(Stream 1 waits for H2D)"
  Stream1 -> WindowStage: "6: process(d_input, d_input)"
  WindowStage -> WindowStage: "7: apply_window_kernel<<<>>>\n(Shape: [channels, nfft])"

  Stream1 -> FFTStage: "8: process(d_input, d_intermediate)"
  FFTStage -> FFTStage: "9: cufftExecR2C()\n(Output: [channels, nfft/2+1])"

  Stream1 -> MagnitudeStage: "10: process(d_intermediate, d_output)"
  MagnitudeStage -> MagnitudeStage: "11: magnitude_kernel<<<>>>\n(Shape: [channels, frames, bins])"

  Stream1 -> Stream1: "12: record event_compute_done"

  # Device to Host Transfer
  d2h_header: {
    shape: text
    label: "PPP Device to Host Transfer PPP"
    style: {
      stroke-width: 0
      font-size: 14
      bold: true
    }
  }

  Stream2 -> Stream1: "13: wait(event_compute_done)\n(Stream 2 waits for compute)"
  Stream2 -> Stream2: "14: copy_to_host(output)"

  # Synchronization
  sync_header: {
    shape: text
    label: "PPP Synchronization PPP"
    style: {
      stroke-width: 0
      font-size: 14
      bold: true
    }
  }

  Impl -> Stream2: "15: synchronize()\n(Block until D2H complete)"
  Stream2 -> Impl: "16: D2H complete"

  Impl -> Impl: "17: update_stats(event_start, event_end)\n(Update latency, throughput, frames_processed)"

  Impl -> BatchExecutor: "18: submit complete"
  BatchExecutor -> Client: "19: return (output ready)"

  performance_note: {
    shape: text
    label: |md
      **Performance**: Mean latency 86.79 µs
      Direct pipeline = minimal overhead
      Ideal for high-throughput batch processing
    |
    style: {
      stroke: "#FFD700"
      fill: "#FFFACD"
    }
  }
}

# ==============================================================================
# Streaming Executor Pipeline (Continuous Streaming Mode)
# ==============================================================================
streaming_mode: Streaming Executor Pipeline {
  style: {
    fill: "#E6FFE6"
    stroke: "#228B22"
    stroke-width: 2
  }

  description: |md
    **Streaming Mode: Ring Buffer Accumulation + Frame Extraction**
    - Supports arbitrary input chunk sizes
    - Per-channel independent processing
    - Ring buffer capacity: 3× NFFT per channel
    - Mean latency: 122.25 µs (+40% vs batch)
    - Ideal for real-time continuous streaming
  |

  # Actor definitions
  Client: {shape: rectangle}
  StreamingExecutor: {shape: rectangle}
  Impl: {
    shape: rectangle
    label: "StreamingExecutor::Impl"
  }
  RingBuffer: {
    shape: rectangle
    label: "RingBuffer[ch]"
  }
  Staging: {
    shape: rectangle
    label: "h_batch_staging"
  }
  Stream0: {
    shape: rectangle
    label: "Stream[0]\nH2D"
  }
  Stream1: {
    shape: rectangle
    label: "Stream[1]\nCompute"
  }
  Stream2: {
    shape: rectangle
    label: "Stream[2]\nD2H"
  }
  WindowStage: {shape: rectangle}
  FFTStage: {shape: rectangle}
  MagnitudeStage: {shape: rectangle}

  # Sequence flow
  Client -> StreamingExecutor: "1: submit(input, output, num_samples)"
  StreamingExecutor -> Impl: "2: submit_impl(input, output, num_samples)"

  # Ring Buffer Accumulation
  accumulation_header: {
    shape: text
    label: "PPP Ring Buffer Accumulation (Per-Channel) PPP"
    style: {
      stroke-width: 0
      font-size: 14
      bold: true
    }
  }

  Impl -> RingBuffer: "3: for each channel:\npush(input_chunk[ch], num_samples)"
  RingBuffer -> RingBuffer: "4: Lock-free push\nAtomic write_pos update"
  RingBuffer -> Impl: "5: push complete"

  # Frame Extraction Loop
  extraction_header: {
    shape: text
    label: "PPP Frame Extraction Loop PPP"
    style: {
      stroke-width: 0
      font-size: 14
      bold: true
    }
  }

  loop_note: {
    shape: text
    label: |md
      **Loop: while can_extract_frame(nfft)**
      Process all complete frames available in ring buffers
    |
    style: {
      stroke: "#228B22"
      fill: "#F0FFF0"
    }
  }

  Impl -> RingBuffer: "6: extract_batch(staging, nfft, 1, hop_size)"
  RingBuffer -> RingBuffer: "7: Extract overlapping frame\nfor all channels"
  RingBuffer -> Staging: "8: frame data in staging"

  # Host to Device Transfer
  h2d_stream_header: {
    shape: text
    label: "PPP Host to Device Transfer PPP"
    style: {
      stroke-width: 0
      font-size: 14
      bold: true
    }
  }

  Staging -> Stream0: "9: copy_from_host(staging)\n(Shape: [channels, nfft])"
  Stream0 -> Stream0: "10: record event_h2d_done"

  # Compute Pipeline
  compute_stream_header: {
    shape: text
    label: "PPP Compute Pipeline PPP"
    style: {
      stroke-width: 0
      font-size: 14
      bold: true
    }
  }

  Stream1 -> Stream0: "11: wait(event_h2d_done)"
  Stream1 -> WindowStage: "12: process(d_input, d_input)"
  WindowStage -> WindowStage: "13: apply_window_kernel<<<>>>\n(Shape: [channels, nfft])"

  Stream1 -> FFTStage: "14: process(d_input, d_intermediate)"
  FFTStage -> FFTStage: "15: cufftExecR2C()\n(Output: [channels, nfft/2+1])"

  Stream1 -> MagnitudeStage: "16: process(d_intermediate, d_output)"
  MagnitudeStage -> MagnitudeStage: "17: magnitude_kernel<<<>>>\n(Shape: [channels, bins])"

  Stream1 -> Stream1: "18: record event_compute_done"

  # Device to Host Transfer
  d2h_stream_header: {
    shape: text
    label: "PPP Device to Host Transfer PPP"
    style: {
      stroke-width: 0
      font-size: 14
      bold: true
    }
  }

  Stream2 -> Stream1: "19: wait(event_compute_done)"
  Stream2 -> Stream2: "20: copy_to_host(output_frame)\n(Transfer one frame result)"

  # Advance Ring Buffer
  advance_header: {
    shape: text
    label: "PPP Advance Ring Buffer PPP"
    style: {
      stroke-width: 0
      font-size: 14
      bold: true
    }
  }

  Impl -> RingBuffer: "21: advance(hop_size)\n(Move read pointer for overlap)"
  Impl -> Impl: "22: frames_processed++"

  loop_end: {
    shape: text
    label: "PPP End Frame Extraction Loop PPP"
    style: {
      stroke-width: 0
      font-size: 14
      italic: true
    }
  }

  # Synchronization
  sync_stream_header: {
    shape: text
    label: "PPP Synchronization PPP"
    style: {
      stroke-width: 0
      font-size: 14
      bold: true
    }
  }

  Impl -> Stream2: "23: synchronize()\n(Wait for last frame D2H)"
  Stream2 -> Impl: "24: last frame complete"

  Impl -> Impl: "25: update_stats(event_start, event_end)\n(Update latency, throughput, frames_processed)"

  Impl -> StreamingExecutor: "26: submit complete"
  StreamingExecutor -> Client: "27: return (last frame in output)"

  performance_stream_note: {
    shape: text
    label: |md
      **Performance**: Mean latency 122.25 µs (+40% vs batch)
      **Ring Buffer Overhead**:
      - Memory: +80% (3× NFFT × channels + staging)
      - Latency: +40% (buffer management overhead)

      Tradeoff: Flexibility for arbitrary chunk sizes
      Ideal for real-time continuous streaming
    |
    style: {
      stroke: "#FFD700"
      fill: "#FFFACD"
    }
  }
}

# ==============================================================================
# Comparison Note
# ==============================================================================
comparison: |md
  # Batch vs Streaming Mode Comparison

  ## Batch Executor (High-Throughput)
  - **Direct pipeline**: H2D ’ Compute ’ D2H
  - **Fixed input size**: Must provide complete frames
  - **Lower latency**: 86.79 µs
  - **Lower memory**: 164 KB
  - **Use case**: Offline batch processing, file analysis

  ## Streaming Executor (Low-Latency Real-Time)
  - **Ring buffer accumulation**: Flexible chunk sizes
  - **Frame extraction**: Overlapping frame extraction on demand
  - **Higher latency**: 122.25 µs (+40%)
  - **Higher memory**: 295 KB (+80%)
  - **Use case**: Real-time streaming, continuous monitoring

  Both modes use the same 3-stream asynchronous pipeline for parallel H2D/Compute/D2H.
|

comparison.style: {
  stroke: "#4169E1"
  fill: "#E6F3FF"
}
