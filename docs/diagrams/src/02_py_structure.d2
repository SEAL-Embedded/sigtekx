# ==============================================================================
# Core Relationships
# ==============================================================================
core_package.Engine -> core_package.CppEngine: wraps
core_package.Engine -> config_package.EngineConfig: configured by
core_package.Engine -> config_package.PresetFunctions: uses presets {
  class: dependency
}
core_package.PipelineBuilder -> core_package.Engine: initializes
core_package.CppEngine -> cpp_extension.ResearchEngine: binds

# ==============================================================================
# Benchmark Relationships
# ==============================================================================
benchmarks_package.BaseBenchmark -> benchmarks_package.BenchmarkConfig: configured by
benchmarks_package.LatencyBenchmark -> core_package.Engine: uses
benchmarks_package.ThroughputBenchmark -> core_package.Engine: uses
benchmarks_package.AccuracyBenchmark -> core_package.Engine: uses
benchmarks_package.RealtimeBenchmark -> core_package.Engine: uses
benchmarks_package.BaseBenchmark -> utils_package.GpuClockManager: locks clocks {
  class: dependency
}

# ==============================================================================
# Config Validation Relationships
# ==============================================================================
config_package.ValidationFunctions -> config_package.EngineConfig: validates
core_package.Engine -> config_package.ValidationFunctions: uses {
  class: dependency
}

# ==============================================================================
# Utils Relationships
# ==============================================================================
core_package.Engine -> utils_package.device_functions: queries device {
  class: dependency
}
core_package.Engine -> utils_package.logging_functions: logs {
  class: dependency
}
benchmarks_package.BaseBenchmark -> utils_package.signal_functions: generates test data {
  class: dependency
}
benchmarks_package.BaseBenchmark -> utils_package.profiling_module: instruments {
  class: dependency
}
benchmarks_package.BaseBenchmark -> utils_package.DataArchiver: stores results {
  class: dependency
}
benchmarks_package.AccuracyBenchmark -> utils_package.validation_functions: validates results {
  class: dependency
}
utils_package.signal_functions -> utils_package.reproducibility_functions: uses DeterministicGenerator {
  class: dependency
}
utils_package.path_functions -> utils_package.logging_functions: shares logger {
  class: dependency
}

# ==============================================================================
# External Dependency Relationships
# ==============================================================================
core_package.Engine -> external_deps.NumPy: processes arrays {
  class: dependency
}
utils_package.signal_functions -> external_deps.NumPy: generates {
  class: dependency
}
utils_package.signal_functions -> external_deps.SciPy: filters {
  class: dependency
}
config_package.EngineConfig -> external_deps.Pydantic: validates {
  class: dependency
}
utils_package.profiling_module -> external_deps.NVTX: wraps {
  class: dependency
}
utils_package.device_functions -> external_deps.PyNVML: queries {
  class: dependency
