exceptions_package: ionosense_hpc.exceptions {
  class: execution-red

  IonosenseError: |md
    **IonosenseError**
    «Base Exception»

    + message: str
    + hint: str
    + context: dict
  |
  IonosenseError.shape: class
  IonosenseError.class: exception-pink

  # Configuration & Validation Errors
  ConfigError: |md
    **ConfigError**

    + field: str
    + value: Any
