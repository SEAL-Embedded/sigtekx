  |
  BenchmarkValidationError.shape: class

  ExperimentError: |md
    **ExperimentError**

    + experiment_id: str
  |
  ExperimentError.shape: class

  ReproducibilityError: |md
    **ReproducibilityError**

    + missing_info: list
  |
  ReproducibilityError.shape: class

  EnvironmentMismatchError: |md
    **EnvironmentMismatchError**

    + expected: dict
    + actual: dict
    + differences: list
  |
  EnvironmentMismatchError.shape: class

  DataIntegrityError: |md
    **DataIntegrityError**

    + expected_hash: str
    + actual_hash: str
  |
  DataIntegrityError.shape: class

  # Analysis & Reporting Errors
  AnalysisError: |md
    **AnalysisError**

    + analysis_type: str
  |
  AnalysisError.shape: class

  ReportGenerationError: |md
    **ReportGenerationError**

    + report_format: str
  |
  ReportGenerationError.shape: class

  InsufficientDataError: |md
    **InsufficientDataError**

    + required: int
    + actual: int
  |
  InsufficientDataError.shape: class

  # Workflow & Orchestration Errors
  WorkflowError: |md
    **WorkflowError**

    + workflow_stage: str
  |
  WorkflowError.shape: class

  DependencyError: |md
    **DependencyError**

    + missing_dependencies: list
  |
  DependencyError.shape: class

  ResourceExhaustedError: |md
    **ResourceExhaustedError**

    + resource_type: str
    + required: Any
    + available: Any
  |
  ResourceExhaustedError.shape: class

  # Exception hierarchy - Level 1
  ConfigError -> IonosenseError: extends
  ValidationError -> IonosenseError: extends
  DeviceNotFoundError -> IonosenseError: extends
  DllLoadError -> IonosenseError: extends
  EngineStateError -> IonosenseError: extends
  EngineRuntimeError -> IonosenseError: extends
  BenchmarkError -> IonosenseError: extends
  ExperimentError -> IonosenseError: extends
  ReproducibilityError -> IonosenseError: extends
  DataIntegrityError -> IonosenseError: extends
  AnalysisError -> IonosenseError: extends
  ReportGenerationError -> IonosenseError: extends
  WorkflowError -> IonosenseError: extends
  ResourceExhaustedError -> IonosenseError: extends

  # Exception hierarchy - Level 2
  BenchmarkTimeoutError -> BenchmarkError: extends
  BenchmarkValidationError -> BenchmarkError: extends
  EnvironmentMismatchError -> ReproducibilityError: extends
  InsufficientDataError -> AnalysisError: extends
  DependencyError -> WorkflowError: extends
}

