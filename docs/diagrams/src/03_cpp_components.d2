# ==============================================================================
# Cross-layer Relationships
# ==============================================================================

# Python to C++ bindings
python_layer.PyBind11 -> executor_api.BatchExecutor: binds
python_layer.PyBind11 -> executor_api.StreamingExecutor: binds

# Executor resource management
executor_api.BatchExecutor -> cuda_resources.CudaStream: manages
executor_api.StreamingExecutor -> cuda_resources.CudaStream: manages
executor_api.BatchExecutor -> cuda_resources.CudaEvent: synchronizes
executor_api.StreamingExecutor -> cuda_resources.CudaEvent: synchronizes
executor_api.BatchExecutor -> cuda_resources.DeviceBuffer: allocates
executor_api.StreamingExecutor -> cuda_resources.DeviceBuffer: allocates
executor_api.BatchExecutor -> cuda_resources.PinnedHostBuffer: "stages\n(2 buffers)"
executor_api.StreamingExecutor -> cuda_resources.PinnedHostBuffer: "stages\n(2 buffers)"

# Streaming-specific components
executor_api.StreamingExecutor -> streaming_components.RingBuffer: uses
streaming_components.RingBuffer -> cuda_resources.PinnedHostBuffer: "owns ring\nbuffers"

# Pipeline initialization flow (executors receive stages from builder/factory)
executor_api.IPipelineExecutor <- processing_pipeline.PipelineBuilder: "provides\nstages to"
executor_api.BatchExecutor <- processing_pipeline.IProcessingStage: "owns\nvector<>" {
  class: dependency
}
executor_api.StreamingExecutor <- processing_pipeline.IProcessingStage: "owns\nvector<>" {
  class: dependency
}

# Pipeline orchestration (executors call stage process() methods)
executor_api.BatchExecutor -> processing_pipeline.WindowStage: orchestrates {
  class: dependency
}
executor_api.BatchExecutor -> processing_pipeline.FFTStage: orchestrates {
  class: dependency
}
executor_api.BatchExecutor -> processing_pipeline.MagnitudeStage: orchestrates {
  class: dependency
}
executor_api.StreamingExecutor -> processing_pipeline.WindowStage: orchestrates {
  class: dependency
}
executor_api.StreamingExecutor -> processing_pipeline.FFTStage: orchestrates {
  class: dependency
}
executor_api.StreamingExecutor -> processing_pipeline.MagnitudeStage: orchestrates {
  class: dependency
}

# Stage to kernel relationships
processing_pipeline.WindowStage -> cuda_kernels.WindowKernels: launches
processing_pipeline.FFTStage -> cuda_kernels.FFTKernels: executes
processing_pipeline.MagnitudeStage -> cuda_kernels.MagnitudeKernels: launches

# Stage resource usage
processing_pipeline.WindowStage -> cuda_resources.DeviceBuffer: uses
processing_pipeline.FFTStage -> cuda_resources.CufftPlan: uses
processing_pipeline.MagnitudeStage -> cuda_resources.DeviceBuffer: uses

# Memory space relationships
cuda_resources.CudaStream -> gpu_memory: commands
cuda_resources.CudaEvent -> gpu_memory: synchronizes
cuda_resources.DeviceBuffer -> gpu_memory: allocates
cuda_resources.PinnedHostBuffer -> host_memory: allocates

# Profiling integration
executor_api.BatchExecutor -> profiling_debug.NVTX: instruments {
  style.stroke-dash: 3
}
executor_api.StreamingExecutor -> profiling_debug.NVTX: instruments {
  style.stroke-dash: 3
}
executor_api.BatchExecutor -> profiling_debug.Metrics: collects {
  style.stroke-dash: 3
}
executor_api.StreamingExecutor -> profiling_debug.Metrics: collects {
  style.stroke-dash: 3
}
processing_pipeline.WindowStage -> profiling_debug.NVTX: instruments {
  style.stroke-dash: 3
}
processing_pipeline.FFTStage -> profiling_debug.NVTX: instruments {
  style.stroke-dash: 3
}
processing_pipeline.MagnitudeStage -> profiling_debug.NVTX: instruments {
  style.stroke-dash: 3
}

# Utility namespace usage
processing_pipeline.WindowStage -> utilities.window_utils: uses {
  style.stroke-dash: 3
}
executor_api.SignalConfig <- utilities.signal_utils: validates {
  style.stroke-dash: 3
}
executor_api.ExecutorConfig <- utilities.signal_utils: validates {
  style.stroke-dash: 3
}

