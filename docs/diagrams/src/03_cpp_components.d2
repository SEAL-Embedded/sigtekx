# Ionosense HPC - C++ Component Architecture
# Layout: dagre - hierarchical component relationships with clear top-down data flow
# Render: See docs/diagrams/README.md for rendering instructions
# 
# This diagram shows the complete component architecture of the Ionosense HPC library,
# including interfaces (IPipelineExecutor, IProcessingStage), concrete implementations,
# the Builder pattern (PipelineBuilder), and all configuration/resource relationships.
# 
# AUDIT STATUS: ✓ Verified accurate against codebase (2025-12-02)

# Import shared styles
...@common/styles

direction: down

# ==============================================================================
# Python Bindings Layer
# ==============================================================================
python_layer: Python Bindings Layer {
  class: execution-red

  PyBatchExecutor: {
    shape: rectangle
    label: "PyBatchExecutor"
  }

  PyStreamingExecutor: {
    shape: rectangle
    label: "PyStreamingExecutor"
  }

  PyBind11: {
    shape: rectangle
    label: "pybind11 Module"
  }

  PyBatchExecutor -> PyBind11: wraps
  PyStreamingExecutor -> PyBind11: wraps
}

# ==============================================================================
# C++ Executor API (Interfaces + Implementations)
# ==============================================================================
executor_api: C++ Executor API {
  class: core-blue

  # Abstract Interface
  IPipelineExecutor: {
    shape: rectangle
    label: "IPipelineExecutor\n«interface»"
    style: {
      stroke-dash: 3
      italic: true
    }

    note: |md
      **Abstract executor interface**
      - initialize()
      - submit() / submit_async()
      - synchronize()
      - get_stats()
      - supports_streaming()

      Strategy pattern for execution
    |
  }

  # Concrete Implementations
  BatchExecutor: {
    shape: rectangle
    label: "BatchExecutor"

    note: |md
      **Batch Mode (High-Throughput)**
      - Direct pipeline processing
      - NumPy array interface
      - Mean latency: 86.79 µs
      - Direct H2D → Compute → D2H
      - Pimpl idiom hides CUDA dependencies
    |
  }

  StreamingExecutor: {
    shape: rectangle
    label: "StreamingExecutor"

    note: |md
      **Streaming Mode (Low-Latency)**
      - Ring buffer accumulation
      - Arbitrary chunk sizes
      - Mean latency: 122.25 µs
      - Ring buffer → Extract → Pipeline
      - Pimpl idiom hides CUDA dependencies
    |
  }

  # Configuration Structures
  ExecutorConfig: {
    shape: rectangle
    label: "ExecutorConfig"

    note: |md
      - ExecutionMode (BATCH/STREAMING)
      - max_inflight_batches
      - device_id
      - enable_background_thread
    |
  }

  SignalConfig: {
    shape: rectangle
    label: "SignalConfig"

    note: |md
      - nfft, channels, overlap
      - sample_rate_hz
      - window params
      - stream_count, buffer_count
    |
  }

  ProcessingStats: {
    shape: rectangle
    label: "ProcessingStats"
  }

  # Inheritance relationships (implements interface)
  BatchExecutor -> IPipelineExecutor: implements {
    style: {
      stroke-dash: 3
    }
  }
  StreamingExecutor -> IPipelineExecutor: implements {
    style: {
      stroke-dash: 3
    }
  }

  # Configuration inheritance
  ExecutorConfig -> SignalConfig: extends {
    style: {
      stroke-dash: 3
    }
  }

  # Configuration relationships
  BatchExecutor <- ExecutorConfig: configured by
  StreamingExecutor <- ExecutorConfig: configured by

  # Stats generation
  BatchExecutor -> ProcessingStats: generates
  StreamingExecutor -> ProcessingStats: generates
}

# ==============================================================================
# Streaming Components
# ==============================================================================
streaming_components: Streaming Components {
  class: streaming-green

  RingBuffer: {
    shape: rectangle
    label: "RingBuffer<T>"

    note: |md
      **Per-channel ring buffers**
      - Template class for type-safety
      - Capacity: 3× NFFT
      - Lock-free thread-safe (atomic ops)
      - CUDA pinned memory (PinnedHostBuffer)

      **Operations:**
      - push() / extract_frame() / extract_batch()
      - advance() / available() / reset()

      **Memory Overhead: +80%**
      - 3× NFFT × channels (ring buffers)
      - + nfft × channels (staging)
      - = 295 KB vs 164 KB (batch)
    |
  }
}

# ==============================================================================
# Processing Pipeline (Interfaces + Implementations + Builder)
# ==============================================================================
processing_pipeline: Processing Pipeline {
  class: core-blue

  # Abstract Stage Interface
  IProcessingStage: {
    shape: rectangle
    label: "IProcessingStage\n«interface»"
    style: {
      stroke-dash: 3
      italic: true
    }

    note: |md
      **Abstract stage interface**
      - initialize(config, stream)
      - process(input, output, size, stream)
      - name()
      - supports_inplace()
      - get_workspace_size()

      Strategy pattern for pipeline stages
    |
  }

  # Concrete Stage Implementations
  WindowStage: {
    shape: rectangle
    label: "WindowStage"

    note: |md
      Applies window function
      - Hann, Blackman, Rectangular
      - Periodic/Symmetric modes
      - GPU-resident window buffer
    |
  }

  FFTStage: {
    shape: rectangle
    label: "FFTStage"

    note: |md
      Executes FFT via cuFFT
      - R2C transform
      - Batched execution
      - Work area management
    |
  }

  MagnitudeStage: {
    shape: rectangle
    label: "MagnitudeStage"

    note: |md
      Computes magnitude spectrum
      - sqrt(real² + imag²)
      - Optional scaling
      - CUDA kernel
    |
  }

  # Stage Factory (Factory Pattern)
  StageFactory: {
    shape: rectangle
    label: "StageFactory"

    note: |md
      **Factory for stage creation**
      - create(StageType)
      - create_default_pipeline()

      Returns `unique_ptr<IProcessingStage>`
    |
  }

  # Pipeline Builder (Builder Pattern)
  PipelineBuilder: {
    shape: rectangle
    label: "PipelineBuilder"

    note: |md
      **Fluent builder for pipelines**
      - with_config(StageConfig)
      - add_window() / add_fft() / add_magnitude()
      - validate()
      - estimate_memory_usage()
      - build() → `vector<unique_ptr<IProcessingStage>>`

      Builder pattern for stage composition
    |
  }

  # Stage Configuration
  StageConfig: {
    shape: rectangle
    label: "StageConfig"

    note: |md
      **Pipeline stage configuration**
      - nfft, channels, overlap
      - WindowType (HANN/BLACKMAN/RECTANGULAR)
      - WindowSymmetry (PERIODIC/SYMMETRIC)
      - ScalePolicy (NONE/ONE_OVER_N/ONE_OVER_SQRT_N)
      - OutputMode (MAGNITUDE/COMPLEX_PASSTHROUGH)
    |
  }

  # Inheritance relationships (implements interface)
  WindowStage -> IProcessingStage: implements {
    style: {
      stroke-dash: 3
    }
  }
  FFTStage -> IProcessingStage: implements {
    style: {
      stroke-dash: 3
    }
  }
  MagnitudeStage -> IProcessingStage: implements {
    style: {
      stroke-dash: 3
    }
  }

  # Factory relationships
  StageFactory -> WindowStage: creates
  StageFactory -> FFTStage: creates
  StageFactory -> MagnitudeStage: creates

  # Builder relationships
  PipelineBuilder -> StageFactory: uses
  PipelineBuilder -> StageConfig: configured by
  PipelineBuilder -> IProcessingStage: "builds\nvector<>"

  # Configuration relationships
  WindowStage <- StageConfig: configured by
  FFTStage <- StageConfig: configured by
  MagnitudeStage <- StageConfig: configured by
}

# ==============================================================================
# CUDA Resource Management (RAII Wrappers)
# ==============================================================================
cuda_resources: CUDA Resource Management {
  class: cuda-resource

  CudaStream: {
    shape: rectangle
    label: "CudaStream"

    note: |md
      **RAII wrapper for cudaStream_t**
      - Move-only (unique ownership)
      - Non-blocking streams
      - synchronize() / query()

      Defined in cuda_wrappers.hpp
    |
  }

  CudaEvent: {
    shape: rectangle
    label: "CudaEvent"

    note: |md
      **RAII wrapper for cudaEvent_t**
      - Move-only (unique ownership)
      - Timing disabled by default
      - record() / synchronize() / query()

      Defined in cuda_wrappers.hpp
    |
  }

  DeviceBuffer: {
    shape: rectangle
    label: "DeviceBuffer<T>"

    note: |md
      **RAII wrapper for device memory**
      - Template class for type-safety
      - Move-only (unique ownership)
      - resize() / memset()
      - copy_from_host() / copy_to_host()

      Defined in cuda_wrappers.hpp
    |
  }

  PinnedHostBuffer: {
    shape: rectangle
    label: "PinnedHostBuffer<T>"

    note: |md
      **RAII wrapper for pinned memory**
      - Template class for type-safety
      - Move-only (unique ownership)
      - Page-locked for fast DMA
      - resize() / memset()

      Defined in cuda_wrappers.hpp
    |
  }

  CufftPlan: {
    shape: rectangle
    label: "CufftPlan"

    note: |md
      **RAII wrapper for cufftHandle**
      - Move-only (unique ownership)
      - Work area management
      - create_plan_many()
      - exec_r2c()

      Defined in cuda_wrappers.hpp
    |
  }
}

# ==============================================================================
# CUDA Kernels (Device Code)
# ==============================================================================
cuda_kernels: CUDA Kernels {
  class: kernel-orange

  WindowKernels: {
    shape: rectangle
    label: "Window Kernels"

    note: |md
      **CUDA kernels in fft_wrapper.cu**
      - apply_window_kernel()
      - apply_window_complex_kernel()

      Launch wrapper: launch_apply_window()
    |
  }

  FFTKernels: {
    shape: rectangle
    label: "FFT Kernels\n(cuFFT)"

    note: |md
      **cuFFT library functions**
      - cufftExecR2C()

      Wrapped by CufftPlan RAII class
    |
  }

  MagnitudeKernels: {
    shape: rectangle
    label: "Magnitude Kernels"

    note: |md
      **CUDA kernels in fft_wrapper.cu**
      - magnitude_kernel()
      - magnitude_squared_kernel()

      Launch wrapper: launch_magnitude()
    |
  }
}

