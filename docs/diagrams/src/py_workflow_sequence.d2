  }

  step1: "1: CLI → DVC: track artifacts" {shape: rectangle}
  step2: "2: DVC → Artifacts: compute hashes" {shape: rectangle}
  step3: "3: DVC: update dvc.lock" {shape: rectangle}
  step4: "4: DVC → CLI: tracking updated" {shape: rectangle}
  step5: "5: CLI → Researcher: Analysis complete!" {shape: rectangle}
  step6: "6: Researcher → CLI: iono ui" {shape: rectangle}
  step7: "7: CLI → MLflow: mlflow ui" {shape: rectangle}
  step8: "8: MLflow → Researcher: http://localhost:5000" {shape: rectangle}
  step9: "9: Researcher: review results in MLflow UI" {shape: rectangle}

  step1 -> step2 -> step3 -> step4 -> step5 -> step6 -> step7 -> step8 -> step9
}

