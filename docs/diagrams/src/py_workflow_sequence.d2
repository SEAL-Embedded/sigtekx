# ==============================================================================
# Workflow Flow
# ==============================================================================
init_phase -> cpp_dev_phase: Sequential
cpp_dev_phase -> prod_prof_phase: Sequential
prod_prof_phase -> experiment_phase: Sequential
experiment_phase -> analysis_phase: Sequential
analysis_phase -> visualization_phase: Sequential
visualization_phase -> reporting_phase: Sequential
reporting_phase -> interactive_phase: PRIMARY path
interactive_phase -> review_phase: Sequential
review_phase -> quick_iteration: Optional {
  style.stroke-dash: 3
}
