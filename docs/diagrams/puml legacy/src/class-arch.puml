@startuml "Ionosense HPC - C++ Architecture Overview"
!theme plain
skinparam backgroundColor #FEFEFE
skinparam classBackgroundColor #F0F8FF
skinparam classBorderColor #4169E1
skinparam packageBackgroundColor #E6F3FF
skinparam packageBorderColor #4169E1
skinparam arrowColor #4169E1
skinparam noteBackgroundColor #FFFACD
skinparam noteBorderColor #FFD700

' Spacing controls for better layout
skinparam nodesep 100
skinparam ranksep 80
skinparam packageStyle rectangle

title Ionosense HPC Library - C++ Architecture (v0.9.4+ Executor-Based)
footer PlantUML Diagram - © 2025 | Updated: 2025-01-19

' Define packages for logical grouping
package "Executor API Layer" #E6F3FF {
  interface IPipelineExecutor {
    {abstract} +initialize(config: ExecutorConfig, stages: vector<IProcessingStage>): void
    {abstract} +submit(input: float*, output: float*, num_samples: size_t): void
    {abstract} +submit_async(input: float*, num_samples: size_t, callback: ResultCallback): void
    {abstract} +synchronize(): void
    {abstract} +get_stats(): ProcessingStats
    {abstract} +get_runtime_info(): RuntimeInfo
    {abstract} +supports_streaming(): bool
  }

  class BatchExecutor {
    -pImpl: unique_ptr<Impl>
    --
    +BatchExecutor()
    +~BatchExecutor()
    +initialize(config: ExecutorConfig, stages: vector<IProcessingStage>): void
    +submit(input: float*, output: float*, num_samples: size_t): void
    +submit_async(input: float*, num_samples: size_t, callback: ResultCallback): void
    +synchronize(): void
    +get_stats(): ProcessingStats
    +get_runtime_info(): RuntimeInfo
    +supports_streaming(): bool  // returns false
  }

  class "BatchExecutor::Impl" as BatchExecutorImpl <<(P,orchid) Pimpl>> {
    -config_: ExecutorConfig
    -device_id_: int
    -device_props_: cudaDeviceProp
    -stages_: vector<unique_ptr<IProcessingStage>>
    -streams_: vector<CudaStream>
    -events_: vector<CudaEvent>
    -d_input_buffers_: vector<DeviceBuffer<float>>
    -d_intermediate_buffers_: vector<DeviceBuffer<float>>
    -d_output_buffers_: vector<DeviceBuffer<float>>
    -h_input_staging_: PinnedHostBuffer<float>
    -h_output_staging_: PinnedHostBuffer<float>
    -initialized_: bool
    -frame_counter_: uint64_t
    -stats_: ProcessingStats
    --
    +submit_impl(input: float*, output: float*, num_samples: size_t): void
    +run_warmup(): void
    +update_stats(start_event: CudaEvent&, end_event: CudaEvent&): void
  }

  class StreamingExecutor {
    -pImpl: unique_ptr<Impl>
    --
    +StreamingExecutor()
    +~StreamingExecutor()
    +initialize(config: ExecutorConfig, stages: vector<IProcessingStage>): void
    +submit(input: float*, output: float*, num_samples: size_t): void
    +submit_async(input: float*, num_samples: size_t, callback: ResultCallback): void
    +synchronize(): void
    +get_stats(): ProcessingStats
    +get_runtime_info(): RuntimeInfo
    +supports_streaming(): bool  // returns true
  }

  class "StreamingExecutor::Impl" as StreamingExecutorImpl <<(P,orchid) Pimpl>> {
    -config_: ExecutorConfig
    -device_id_: int
    -device_props_: cudaDeviceProp
    -stages_: vector<unique_ptr<IProcessingStage>>
    -input_ring_buffers_: vector<RingBuffer<float>>
    -streams_: vector<CudaStream>
    -events_: vector<CudaEvent>
    -d_input_buffers_: vector<DeviceBuffer<float>>
    -d_intermediate_buffers_: vector<DeviceBuffer<float>>
    -d_output_buffers_: vector<DeviceBuffer<float>>
    -h_batch_staging_: PinnedHostBuffer<float>
    -h_output_staging_: PinnedHostBuffer<float>
    -initialized_: bool
    -frame_counter_: uint64_t
    -stats_: ProcessingStats
    --
    +submit_impl(input: float*, output: float*, num_samples: size_t): void
    +run_warmup(): void
    +process_accumulated_frames(): void
    +update_stats(start_event: CudaEvent&, end_event: CudaEvent&): void
  }
}

package "Ring Buffer for Streaming" #E6FFE6 {
  class "RingBuffer<T>" as RingBuffer <<template>> {
    -buffer_: PinnedHostBuffer<T>
    -capacity_: size_t
    -write_pos_: atomic<size_t>
    -read_pos_: atomic<size_t>
    -available_: atomic<size_t>
    --
    +RingBuffer(capacity: size_t)
    +~RingBuffer()
    +push(data: T*, count: size_t): void
    +extract_frame(output: T*, frame_size: size_t): void
    +extract_batch(output: T*, nfft: size_t, num_frames: size_t, hop_size: size_t): void
    +advance(samples: size_t): void
    +available(): size_t
    +capacity(): size_t
    +can_extract(frame_size: size_t): bool
  }
}

package "Processing Stage Layer" #E6F3FF {
  interface IProcessingStage {
    {abstract} +initialize(config: StageConfig, stream: cudaStream_t): void
    {abstract} +process(input: void*, output: void*, num_elements: size_t, stream: cudaStream_t): void
    {abstract} +name(): string
    {abstract} +supports_inplace(): bool
    {abstract} +get_workspace_size(): size_t
  }

  class WindowStage {
    -pImpl: unique_ptr<Impl>
    --
    +WindowStage()
    +~WindowStage()
    +initialize(config: StageConfig, stream: cudaStream_t): void
    +process(input: void*, output: void*, num_samples: size_t, stream: cudaStream_t): void
    +name(): string
    +supports_inplace(): bool
    +get_workspace_size(): size_t
  }

  class FFTStage {
    -pImpl: unique_ptr<Impl>
    --
    +FFTStage()
    +~FFTStage()
    +initialize(config: StageConfig, stream: cudaStream_t): void
    +process(input: void*, output: void*, num_samples: size_t, stream: cudaStream_t): void
    +name(): string
    +supports_inplace(): bool
    +get_workspace_size(): size_t
  }

  class MagnitudeStage {
    -pImpl: unique_ptr<Impl>
    --
    +MagnitudeStage()
    +~MagnitudeStage()
    +initialize(config: StageConfig, stream: cudaStream_t): void
    +process(input: void*, output: void*, num_samples: size_t, stream: cudaStream_t): void
    +name(): string
    +supports_inplace(): bool
    +get_workspace_size(): size_t
  }

  class StageFactory <<(S,#FF7700) Singleton>> {
    {static} +create(type: StageType): unique_ptr<IProcessingStage>
    {static} +create_default_pipeline(): vector<unique_ptr<IProcessingStage>>
  }

  enum StageType {
    WINDOW
    FFT
    MAGNITUDE
  }
}

package "CUDA Resource Management" #E6F3FF {
  class CudaStream <<(R,lightgreen) RAII>> {
    -stream_: cudaStream_t
    -owned_: bool
    --
    +CudaStream()
    +CudaStream(stream: cudaStream_t)
    +~CudaStream()
    +get(): cudaStream_t
    +synchronize(): void
    +query(): bool
    ..Move-only semantics..
    +CudaStream(&&): CudaStream
    +operator=(&&): CudaStream&
  }

  class CudaEvent <<(R,lightgreen) RAII>> {
    -event_: cudaEvent_t
    --
    +CudaEvent()
    +CudaEvent(flags: unsigned int)
    +~CudaEvent()
    +get(): cudaEvent_t
    +record(stream: cudaStream_t): void
    +synchronize(): void
    +query(): bool
    +elapsed_ms(start: CudaEvent&): float
    ..Move-only semantics..
    +CudaEvent(&&): CudaEvent
    +operator=(&&): CudaEvent&
  }

  class "DeviceBuffer<T>" as DeviceBuffer <<(R,lightgreen) RAII>> {
    -ptr_: T*
    -size_: size_t
    --
    +DeviceBuffer()
    +DeviceBuffer(count: size_t)
    +~DeviceBuffer()
    +get(): T*
    +size(): size_t
    +bytes(): size_t
    +resize(new_count: size_t): void
    +memset(value: int): void
    +copy_from_host(host_ptr: T*, count: size_t, stream: cudaStream_t): void
    +copy_to_host(host_ptr: T*, count: size_t, stream: cudaStream_t): void
    ..Move-only semantics..
    +DeviceBuffer(&&): DeviceBuffer
    +operator=(&&): DeviceBuffer&
  }

  class "PinnedHostBuffer<T>" as PinnedHostBuffer <<(R,lightgreen) RAII>> {
    -ptr_: T*
    -size_: size_t
    --
    +PinnedHostBuffer()
    +PinnedHostBuffer(count: size_t)
    +~PinnedHostBuffer()
    +get(): T*
    +data(): T*
    +size(): size_t
    +bytes(): size_t
    +operator[](idx: size_t): T&
    +resize(new_count: size_t): void
    +memset(value: int): void
    ..Move-only semantics..
    +PinnedHostBuffer(&&): PinnedHostBuffer
    +operator=(&&): PinnedHostBuffer&
  }

  class CufftPlan <<(R,lightgreen) RAII>> {
    -plan_: cufftHandle
    -work_area_: DeviceBuffer<char>
    -work_size_: size_t
    --
    +CufftPlan()
    +~CufftPlan()
    +get(): cufftHandle
    +create_plan_many(...): void
    +exec_r2c(input: cufftReal*, output: cufftComplex*): void
    +work_size(): size_t
    ..Move-only semantics..
    +CufftPlan(&&): CufftPlan
    +operator=(&&): CufftPlan&
  }
}

package "Configuration & Statistics" #E6F3FF {
  class SignalConfig <<(D,lightblue) Data>> {
    +nfft: int = 1024
    +channels: int = 2  // Renamed from 'batch' in v0.9.4
    +overlap: float = 0.5f
    +sample_rate_hz: int = 48000
    +stream_count: int = 3
    +pinned_buffer_count: int = 2
    +warmup_iters: int = 1
    --
    +hop_size(): int
    +num_output_bins(): int
  }

  class ExecutorConfig <<(D,lightblue) Data>> {
    +mode: ExecutionMode = BATCH
    +max_inflight_batches: int = 2
    +enable_background_thread: bool = false
    +timeout_ms: int = 1000
    +use_cuda_graphs: bool = false
    +enable_profiling: bool = false
  }

  enum ExecutionMode {
    BATCH
    STREAMING
  }

  class StageConfig <<(D,lightblue) Data>> {
    +nfft: int = 1024
    +channels: int = 2  // Renamed from 'batch' in v0.9.4
    +overlap: float = 0.5f
    +sample_rate_hz: int = 48000
    +window_type: WindowType = HANN
    +window_symmetry: WindowSymmetry = PERIODIC
    +window_norm: WindowNorm = UNITY
    +preload_window: bool = true
    +scale_policy: ScalePolicy = ONE_OVER_N
    +output_mode: OutputMode = MAGNITUDE
    +inplace: bool = true
    +warmup_iters: int = 1
    --
    +hop_size(): int
  }

  class ProcessingStats <<(D,lightblue) Data>> {
    +latency_us: float = 0.0f
    +throughput_gbps: float = 0.0f
    +frames_processed: size_t = 0  // Temporal FFT windows
    +is_warmup: bool = true
  }

  class RuntimeInfo <<(D,lightblue) Data>> {
    +cuda_version: string
    +cufft_version: string
    +device_name: string
    +device_compute_capability_major: int
    +device_compute_capability_minor: int
    +device_memory_total_mb: size_t
    +device_memory_free_mb: size_t
    +cuda_driver_version: int
    +cuda_runtime_version: int
  }
}

package "CUDA Kernels" <<(K,#FFE4B5) Kernels>> #FFE4B5 {
  class "ops_fft.cu" as OpsFft {
    {static} +apply_window_kernel(): __global__ void
    {static} +apply_window_complex_kernel(): __global__ void
    {static} +real_to_complex_kernel(): __global__ void
    {static} +window_and_convert_kernel(): __global__ void
    {static} +magnitude_kernel(): __global__ void
    {static} +magnitude_strided_kernel(): __global__ void
    {static} +magnitude_squared_kernel(): __global__ void
    {static} +magnitude_to_db_kernel(): __global__ void
    {static} +scale_fft_output_kernel(): __global__ void
    --
    {static} +launch_apply_window(): void
    {static} +launch_real_to_complex(): void
    {static} +launch_window_and_convert(): void
    {static} +launch_magnitude(): void
    {static} +launch_magnitude_squared(): void
    {static} +launch_scale_fft(): void
  }
}

package "Exception Handling" #FFE6E6 {
  class CudaException {
    -error_: cudaError_t
    --
    +CudaException(error: cudaError_t, call: char*, file: char*, line: int)
    +error(): cudaError_t
    -format_message(...): string
  }

  class CufftException {
    -result_: cufftResult
    --
    +CufftException(result: cufftResult, call: char*, file: char*, line: int)
    +result(): cufftResult
    -format_message(...): string
  }
}

' Executor Relationships
BatchExecutor ..|> IPipelineExecutor : implements
StreamingExecutor ..|> IPipelineExecutor : implements
BatchExecutor *--> BatchExecutorImpl : owns (Pimpl)
StreamingExecutor *--> StreamingExecutorImpl : owns (Pimpl)

BatchExecutorImpl o--> "1..*" IProcessingStage : manages
BatchExecutorImpl *--> "1..*" CudaStream : owns
BatchExecutorImpl *--> "1..*" CudaEvent : owns
BatchExecutorImpl *--> "1..*" DeviceBuffer : owns
BatchExecutorImpl *--> "2" PinnedHostBuffer : owns
BatchExecutorImpl ..> ExecutorConfig : uses
BatchExecutorImpl ..> ProcessingStats : generates

StreamingExecutorImpl o--> "1..*" IProcessingStage : manages
StreamingExecutorImpl *--> "channels" RingBuffer : owns (per-channel)
StreamingExecutorImpl *--> "1..*" CudaStream : owns
StreamingExecutorImpl *--> "1..*" CudaEvent : owns
StreamingExecutorImpl *--> "1..*" DeviceBuffer : owns
StreamingExecutorImpl *--> "2" PinnedHostBuffer : owns
StreamingExecutorImpl ..> ExecutorConfig : uses
StreamingExecutorImpl ..> ProcessingStats : generates

RingBuffer *--> PinnedHostBuffer : owns buffer

' Configuration Hierarchy
ExecutorConfig --|> SignalConfig : extends

' Stage Relationships
WindowStage ..|> IProcessingStage : implements
FFTStage ..|> IProcessingStage : implements
MagnitudeStage ..|> IProcessingStage : implements

WindowStage ..> DeviceBuffer : uses
WindowStage ..> StageConfig : uses
FFTStage ..> CufftPlan : uses
FFTStage ..> StageConfig : uses
MagnitudeStage ..> OpsFft : calls
MagnitudeStage ..> StageConfig : uses

StageFactory ..> WindowStage : creates
StageFactory ..> FFTStage : creates
StageFactory ..> MagnitudeStage : creates
StageFactory ..> StageType : uses

CufftPlan *--> DeviceBuffer : owns work_area

' Notes
note right of IPipelineExecutor
  **v0.9.3+ Executor Pattern**
  Replaces old ResearchEngine.
  Two implementations:
  - BatchExecutor (high-throughput)
  - StreamingExecutor (low-latency)
end note

note right of StreamingExecutor
  **Ring Buffer Architecture**
  Per-channel ring buffers enable:
  - Arbitrary input chunk sizes
  - Continuous streaming
  - Independent channel processing
  - 3× NFFT capacity prevents overflow
end note

note right of RingBuffer
  **Lock-Free Thread-Safe**
  Single-producer/single-consumer
  Uses atomic operations for
  thread-safe access
end note

note right of SignalConfig
  **Terminology (v0.9.4)**
  channels = spatial dimension
  frames = temporal dimension
  bins = spectral dimension
end note

note right of IProcessingStage
  **Design Pattern: Strategy**
  Allows flexible pipeline
  composition
end note

note bottom of CudaStream
  **Design Pattern: RAII**
  Automatic resource
  management
end note

@enduml