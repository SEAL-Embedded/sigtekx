@startuml "Ionosense HPC - Streaming Executor Pipeline"
!theme plain
skinparam backgroundColor #FEFEFE
skinparam sequenceParticipantBackgroundColor #E6FFE6
skinparam sequenceParticipantBorderColor #228B22
skinparam sequenceLifeLineBorderColor #228B22
skinparam sequenceArrowColor #228B22
skinparam noteBackgroundColor #FFFACD

title Ionosense HPC - StreamingExecutor Pipeline (Continuous Streaming Mode)
footer IEEE Publication Quality Diagram - © 2025 | Created: 2025-01-19

participant "Client" as Client
participant "StreamingExecutor" as Executor
participant "StreamingExecutor::Impl" as Impl
participant "RingBuffer[ch]" as RingBuffer
participant "h_batch_staging" as Staging
participant "Stream[0]\nH2D" as Stream0
participant "Stream[1]\nCompute" as Stream1
participant "Stream[2]\nD2H" as Stream2
participant WindowStage
participant FFTStage
participant MagnitudeStage

autonumber

note over Client, MagnitudeStage
  **Streaming Mode**: Ring buffer accumulation + frame extraction
  Supports arbitrary input chunk sizes
  Per-channel independent processing
  Ring buffer capacity: 3× NFFT per channel
end note

Client -> Executor: submit(input, output, num_samples)
activate Executor

Executor -> Impl: submit_impl(input, output, num_samples)
activate Impl

== Ring Buffer Accumulation (Per-Channel) ==
loop for each channel
  Impl -> RingBuffer: push(input_chunk[ch], num_samples)
  activate RingBuffer
  note right: Lock-free push\nAtomic write_pos update
  RingBuffer --> Impl:
  deactivate RingBuffer
end

== Frame Extraction Loop ==
note over Impl
  Process all complete frames
  available in ring buffers
end note

loop while can_extract_frame(nfft)

  Impl -> RingBuffer: extract_batch(staging, nfft, 1, hop_size)
  activate RingBuffer
  note right: Extract overlapping frame\nfor all channels
  RingBuffer --> Impl: frame data in staging
  deactivate RingBuffer

  == Host to Device Transfer ==
  Impl -> Stream0: copy_from_host(staging)
  activate Stream0
  note right: Transfer extracted frame\nShape: [channels, nfft]
  Stream0 -> Stream0: record event_h2d_done
  deactivate Stream0

  == Compute Pipeline ==
  Impl -> Stream1: wait(event_h2d_done)
  activate Stream1

  Stream1 -> WindowStage: process(d_input, d_input)
  activate WindowStage
  note right: Apply window function\nShape: [channels, nfft]
  WindowStage -> WindowStage: apply_window_kernel<<<>>>
  WindowStage --> Stream1:
  deactivate WindowStage

  Stream1 -> FFTStage: process(d_input, d_intermediate)
  activate FFTStage
  note right: FFT on all channels\nOutput: [channels, nfft/2+1]
  FFTStage -> FFTStage: cufftExecR2C()
  FFTStage --> Stream1:
  deactivate FFTStage

  Stream1 -> MagnitudeStage: process(d_intermediate, d_output)
  activate MagnitudeStage
  note right: Compute magnitude\nShape: [channels, bins]
  MagnitudeStage -> MagnitudeStage: magnitude_kernel<<<>>>
  MagnitudeStage --> Stream1:
  deactivate MagnitudeStage

  Stream1 -> Stream1: record event_compute_done
  deactivate Stream1

  == Device to Host Transfer ==
  Impl -> Stream2: wait(event_compute_done)
  activate Stream2
  Stream2 -> Stream2: copy_to_host(output_frame)
  note right: Transfer one frame result
  deactivate Stream2

  == Advance Ring Buffer ==
  Impl -> RingBuffer: advance(hop_size)
  activate RingBuffer
  note right: Move read pointer\nfor overlap management
  RingBuffer --> Impl:
  deactivate RingBuffer

  Impl -> Impl: frames_processed++

end

== Synchronization ==
Impl -> Stream2: synchronize()
activate Stream2
note right: Wait for last frame\nD2H complete
Stream2 --> Impl:
deactivate Stream2

Impl -> Impl: update_stats(event_start, event_end)
note right: Update latency, throughput,\nframes_processed
Impl --> Executor:
deactivate Impl

Executor --> Client: return (last frame in output)
deactivate Executor

note over Client
  **Performance**: Mean latency 122.25 µs (+40% vs batch)
  Tradeoff: Flexibility for arbitrary chunk sizes
  Ideal for real-time continuous streaming

  **Ring Buffer Overhead**:
  - Memory: +80% (3× NFFT × channels + staging)
  - Latency: +40% (buffer management overhead)
end note

@enduml
