# Snakefile
# Modern workflow orchestration with ionosphere-focused analysis

configfile: "experiments/conf/config.yaml"

# Define the final outputs we want (new analysis system with dual reports)
rule all:
    input:
        "artifacts/reports/general_performance_report.html",
        "artifacts/reports/ionosphere_research_report.html",
        "artifacts/reports/plots/latency_vs_nfft.html",
        "artifacts/reports/plots/rtf_vs_freq_resolution.html"

# Run ionosphere resolution sweep (high-resolution analysis)
rule run_ionosphere_resolution:
    output:
        touch("artifacts/data/ionosphere_resolution.done")
    shell:
        """
        python benchmarks/run_throughput.py --multirun \
            experiment=ionosphere_resolution \
            +benchmark=throughput
        """

# Run ionosphere temporal characteristics sweep
rule run_ionosphere_temporal:
    output:
        touch("artifacts/data/ionosphere_temporal.done")
    shell:
        """
        python benchmarks/run_throughput.py --multirun \
            experiment=ionosphere_temporal \
            +benchmark=throughput
        """

# Run ionosphere latency sweep
rule run_ionosphere_latency:
    output:
        touch("artifacts/data/ionosphere_latency.done")
    shell:
        """
        python benchmarks/run_latency.py --multirun \
            experiment=ionosphere_resolution \
            +benchmark=latency
        """

# Generate analysis summary using new analysis system
rule analyze_results:
    input:
        "artifacts/data/ionosphere_resolution.done",
        "artifacts/data/ionosphere_temporal.done",
        "artifacts/data/ionosphere_latency.done"
    output:
        "artifacts/analysis/summary.json"
    shell:
        """
        python -m experiments.analysis.cli analyze artifacts/data \
            --output artifacts/analysis/summary.json \
            --experiment-name "Ionosphere HPC Analysis"
        """

# Generate interactive plots
rule generate_plots:
    input:
        "artifacts/data/ionosphere_resolution.done",
        "artifacts/data/ionosphere_temporal.done",
        "artifacts/data/ionosphere_latency.done"
    output:
        "artifacts/reports/plots/latency_vs_nfft.html",
        "artifacts/reports/plots/rtf_vs_freq_resolution.html"
    shell:
        """
        python -m experiments.analysis.cli report artifacts/data \
            --output-dir artifacts/reports \
            --generate-plots
        """

# Generate both reports (general performance + ionosphere research)
rule generate_reports:
    input:
        "artifacts/data/ionosphere_resolution.done",
        "artifacts/data/ionosphere_temporal.done",
        "artifacts/data/ionosphere_latency.done"
    output:
        "artifacts/reports/general_performance_report.html",
        "artifacts/reports/ionosphere_research_report.html"
    shell:
        """
        python -m experiments.analysis.cli report artifacts/data \
            --output-dir artifacts/reports \
            --generate-plots
        """

# Clean all artifacts
rule clean:
    shell:
        """
        python -c "
import shutil, os, glob
dirs_to_clean = ['artifacts/data', 'artifacts/figures', 'artifacts/reports', 'outputs', 'multirun']
for d in dirs_to_clean:
    if os.path.exists(d):
        for item in glob.glob(os.path.join(d, '*')):
            if os.path.isdir(item):
                shutil.rmtree(item)
            else:
                os.remove(item)
        print(f'Cleaned {d}')
print('All artifacts cleaned')
"
        """

# Quick test run with ionosphere test config
rule test:
    shell:
        """
        python benchmarks/run_throughput.py experiment=ionosphere_test +benchmark=throughput
        python benchmarks/run_latency.py experiment=ionosphere_test +benchmark=latency
        python -m experiments.analysis.cli analyze artifacts/data
        python -m experiments.analysis.cli report artifacts/data --output-dir artifacts/reports
        """